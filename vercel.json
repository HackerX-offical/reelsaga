{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd web && npm install",
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "web/api/hls/segment.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "web/node_modules/ffmpeg-static/**"
    },
    "web/api/hls/manifest.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/hls/manifest",
      "destination": "/web/api/hls/manifest"
    },
    {
      "source": "/hls/segment",
      "destination": "/web/api/hls/segment"
    },
    {
      "source": "/api/(?!hls/)(.*)",
      "destination": "https://api.reelsaga.in/$1"
    },
    {
      "source": "/((?!api/|hls/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
