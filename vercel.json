{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd web && npm install",
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/hls/segment.js": {
      "maxDuration": 60,
      "memory": 3008,
      "includeFiles": "web/node_modules/ffmpeg-static/**"
    },
    "api/hls/manifest.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/rs/:path*",
      "destination": "https://api.reelsaga.in/:path*"
    },
    {
      "source": "/hls/manifest",
      "destination": "/api/hls/manifest"
    },
    {
      "source": "/hls/segment",
      "destination": "/api/hls/segment"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
