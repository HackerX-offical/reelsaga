{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/hls/segment.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/hls/manifest",
      "destination": "/api/hls/manifest"
    },
    {
      "source": "/hls/segment",
      "destination": "/api/hls/segment"
    },
    {
      "source": "/((?!api/|hls/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
